# ==============================================================================
# MindMosaic — Root environment reference
# Copy relevant sections to apps/web/.env.local (Next.js) or set in
# Supabase Dashboard > Edge Functions > Secrets (backend services).
# NEVER commit .env.local or any file with real secrets.
# See docs/dev/deployment.md for full variable catalogue.
# ==============================================================================

# --- Supabase (core — all services) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (apps/web Next.js client) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Stripe (test mode — use sk_test_... keys from Stripe Dashboard) ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRICE_ID_STANDARD_MONTHLY=price_your-standard-monthly-id
STRIPE_PRICE_ID_STANDARD_YEARLY=price_your-standard-yearly-id
STRIPE_PRICE_ID_PREMIUM_MONTHLY=price_your-premium-monthly-id
STRIPE_PRICE_ID_PREMIUM_YEARLY=price_your-premium-yearly-id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Inter-service dispatch (jobs-worker — optional, see deployment.md) ---
INTELLIGENCE_SVC_URL=
ANALYTICS_SVC_URL=
ORCHESTRATION_SVC_URL=
ASSESSMENT_SVC_URL=
NOTIFICATIONS_SVC_URL=

# --- Load testing (CI activation — set in GitHub Actions secrets) ---
LOAD_TEST_BASE_URL=
LOAD_TEST_TOKEN=

# --- Playwright E2E (CI activation — set in GitHub Actions secrets) ---
E2E_BASE_URL=
E2E_WEB_URL=
E2E_SUPABASE_URL=
E2E_SUPABASE_ANON_KEY=
E2E_ANON=
