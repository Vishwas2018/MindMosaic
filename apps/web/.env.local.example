# ==============================================================================
# MindMosaic Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file with real secrets.
# ==============================================================================

# --- Supabase ---
# Local emulator URL is fixed; keys are CLI shared defaults — retrieve via
# `npx supabase status` after `npx supabase start`. Replace placeholders below
# with the live values from your `supabase status` output. NEVER paste real
# values into THIS file — see ISSUE-0037.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_<REPLACE_WITH_LOCAL_ANON_KEY>
SUPABASE_SERVICE_ROLE_KEY=sb_secret_<REPLACE_WITH_LOCAL_SERVICE_ROLE_KEY>

# --- Stripe (test mode — use sk_test_... keys from Stripe Dashboard) ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_PRICE_ID_MVP=price_your-price-id

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
